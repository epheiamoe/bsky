{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "bsky": {
      "type": "local",
      "command": ["npx", "-y", "@epheiamoe/bsky-mcp"],
      "enabled": true,
      "environment": {
        "BSKY_HANDLE": "{env:BLUESKY_HANDLE}",
        "BSKY_APP_PASSWORD": "{env:BLUESKY_APP_PASSWORD}",
        "BSKY_ENABLE_WRITE": "true"
      }
    }
  }
}
