{
  "name": "@bsky/tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "echo lint-tui",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@bsky/app": "workspace:^",
    "@bsky/core": "workspace:*",
    "clipboardy": "^5.3.1",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/clipboardy": "^2.0.4",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.18",
    "dotenv": "^16.6.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
