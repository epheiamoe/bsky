{
  "name": "@bsky/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "echo lint-core",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.config.ts tests/e2e.test.ts --reporter=verbose",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "ky": "^1.7.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
