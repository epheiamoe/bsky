{
  "name": "@bsky/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./services/node-python-sandbox": {
      "import": "./dist/services/node-python-sandbox.js",
      "types": "./dist/services/node-python-sandbox.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "echo lint-app",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bsky/core": "workspace:*",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "happy-dom": "^17.6.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
