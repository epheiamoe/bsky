# Bluesky Account
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=your-app-password
# BLUESKY_PDS=https://your-pds.example.com  # Optional: custom PDS host. Leave unset for bsky.social automatic discovery.

# LLM API Key (required for TUI; PWA uses Settings UI)
LLM_API_KEY=sk-your-api-key

# Non-credential settings (model, provider, language, etc.) are stored in:
#   bsky-tui.config.json  (TUI, gitignored — see bsky-tui.config.example.json)
#   localStorage           (PWA, via Settings UI)

# Translation target language (zh/en/ja/ko/fr/de/es)
TRANSLATE_TARGET_LANG=zh
